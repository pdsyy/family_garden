# Скопируй в .env и заполни
PORT=3001
NODE_ENV=production

# Генерировать: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

JWT_EXPIRES_IN=72h

# Данные первого админа (только для init-db.js, потом менять через /api/auth/change-password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Список разрешённых origins через запятую
CORS_ORIGIN=https://your-domain.com

# Путь к БД — на Railway монтируем Volume на /data
DB_PATH=/data/shop.db
