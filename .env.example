# Server
PORT=3001
NODE_ENV=development

# JWT Secret — ОБЯЗАТЕЛЬНО заменить на длинную случайную строку в production
# Сгенерировать можно командой: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production-please

# Token lifetime
JWT_EXPIRES_IN=24h

# Admin defaults — используется только при первом запуске init-db.js
# В production задайте через переменные окружения или смените сразу после первого логина
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# CORS — разрешённый origin фронтенда (через запятую можно несколько)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Database path (относительно корня проекта)
DB_PATH=./db/shop.db
